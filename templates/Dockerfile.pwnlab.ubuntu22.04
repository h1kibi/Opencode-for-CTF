FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    ca-certificates \
    curl \
    file \
    gdb \
    gdbserver \
    git \
    jq \
    ltrace \
    netcat-openbsd \
    patchelf \
    python3 \
    python3-dev \
    python3-pip \
    python3-setuptools \
    qemu-user \
    ruby \
    ruby-dev \
    socat \
    strace \
    tmux \
    vim-tiny \
    xxd \
    binutils \
    gcc-multilib \
    libc6-dbg \
    dwarves \
    ripgrep \
    && rm -rf /var/lib/apt/lists/*

RUN (python3 -m pip install --no-cache-dir --upgrade pip || echo "WARN: optional pip bootstrap failed") \
    && for pkg in pwntools ROPGadget ropper capstone unicorn keystone-engine pyelftools angr claripy z3-solver; do \
      python3 -m pip install --no-cache-dir "$pkg" || echo "WARN: optional pip package failed: $pkg"; \
    done \
    && (gem install one_gadget seccomp-tools || echo "WARN: optional gem install failed: one_gadget/seccomp-tools")

WORKDIR /work
CMD ["bash"]
