FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive \
    TZ=Etc/UTC \
    LC_ALL=C.UTF-8 \
    LANG=C.UTF-8 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

RUN dpkg --add-architecture i386 \
    && sed -i -E 's/Components: main.*/Components: main restricted universe multiverse/g' /etc/apt/sources.list.d/ubuntu.sources || true \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
      apt-transport-https \
      bash-completion \
      binutils \
      binutils-multiarch \
      bsdextrautils \
      bsdmainutils \
      build-essential \
      ca-certificates \
      clang \
      checksec \
      cmake \
      coreutils \
      curl \
      dnsutils \
      elfutils \
      file \
      g++-multilib \
      gcc-multilib \
      gdb \
      gdb-multiarch \
      gdbserver \
      git \
      git-lfs \
      hexedit \
      iproute2 \
      iputils-ping \
      jq \
      less \
      libc6:i386 \
      libc6-dbg \
      libc6-dbg:i386 \
      libc6-dev:i386 \
      libcapstone-dev \
      libffi-dev \
      libglib2.0-dev \
      libncurses6:i386 \
      libncursesw6:i386 \
      libseccomp-dev \
      libssl-dev \
      libstdc++6:i386 \
      ltrace \
      make \
      nasm \
      net-tools \
      netcat-openbsd \
      openssh-client \
      patchelf \
      pkg-config \
      procps \
      python3 \
      python3-dev \
      python3-pip \
      python3-setuptools \
      python3-venv \
      qemu-user \
      qemu-user-static \
      ripgrep \
      ruby \
      ruby-dev \
      socat \
      strace \
      sudo \
      tmux \
      unzip \
      vim \
      wget \
      xxd \
      zip \
      zlib1g:i386 \
    && rm -rf /var/lib/apt/lists/*

RUN (python3 -m pip install --break-system-packages --upgrade pip setuptools wheel || echo "WARN: optional pip bootstrap failed") \
    && for pkg in \
      pwntools \
      ROPGadget \
      ropper \
      capstone \
      unicorn \
      keystone-engine \
      angr \
      claripy \
      z3-solver \
      LibcSearcher \
      requests \
      ipython; \
    do \
      python3 -m pip install --break-system-packages "$pkg" || echo "WARN: optional pip package failed: $pkg"; \
    done \
    && (gem install one_gadget seccomp-tools || echo "WARN: optional gem install failed: one_gadget/seccomp-tools") \
    && printf '#!/usr/bin/env bash\nexec python3 -m pwnlib.commandline.checksec "$@"\n' > /usr/local/bin/checksec \
    && chmod +x /usr/local/bin/checksec

RUN set -eux; \
    git clone --depth=1 https://github.com/hugsy/gef.git /opt/gef || true; \
    git clone --depth=1 https://github.com/pwndbg/pwndbg /opt/pwndbg || true; \
    if [ -x /opt/pwndbg/setup.sh ]; then /opt/pwndbg/setup.sh || echo "WARN: pwndbg setup failed; falling back to gef/plain gdb"; fi; \
    if [ -f /opt/pwndbg/gdbinit.py ]; then printf '\nsource /opt/pwndbg/gdbinit.py\n' > /root/.gdbinit-pwndbg; fi; \
    if [ -f /opt/gef/gef.py ]; then printf '\nsource /opt/gef/gef.py\n' > /root/.gdbinit-gef; fi; \
    if [ -f /root/.gdbinit-pwndbg ]; then cp /root/.gdbinit-pwndbg /root/.gdbinit; elif [ -f /root/.gdbinit-gef ]; then cp /root/.gdbinit-gef /root/.gdbinit; else touch /root/.gdbinit; fi; \
    printf '#!/usr/bin/env bash\nexec gdb -q -x /root/.gdbinit-pwndbg "$@"\n' > /usr/local/bin/gdb-pwndbg; \
    printf '#!/usr/bin/env bash\nexec gdb -q -x /root/.gdbinit-gef "$@"\n' > /usr/local/bin/gdb-gef; \
    chmod +x /usr/local/bin/gdb-pwndbg /usr/local/bin/gdb-gef

RUN printf 'set disassembly-flavor intel\nset pagination off\nset follow-fork-mode child\nset detach-on-fork off\n' >> /root/.gdbinit \
    && printf 'set -g mouse on\nset -g history-limit 100000\nsetw -g mode-keys vi\n' > /root/.tmux.conf \
    && printf '#!/usr/bin/env bash\nset -euo pipefail\nif [[ $# -eq 0 ]]; then exec bash; fi\nexec "$@"\n' > /usr/local/bin/pwnlab-entrypoint \
    && chmod +x /usr/local/bin/pwnlab-entrypoint \
    && printf '#!/usr/bin/env bash\nset +e\necho "[pwnlab-general24] tool check"\nfor c in file readelf objdump nm strings checksec gdb gdbserver python3 ROPGadget ropper one_gadget patchelf qemu-x86_64 qemu-i386 strace ltrace tmux vim git curl wget socat seccomp-tools; do command -v "$c" >/dev/null 2>&1 && echo "OK $c" || echo "MISS $c"; done\n[ -f /opt/pwndbg/gdbinit.py ] && echo "OK pwndbg files" || echo "MISS pwndbg optional"\n[ -f /opt/gef/gef.py ] && echo "OK gef files" || echo "MISS gef optional"\ncommand -v r2 >/dev/null 2>&1 && echo "OK r2" || echo "MISS r2 optional"\npython3 - <<"PY"\nfrom pwn import *\nprint("OK pwntools", context.arch)\ntry:\n import angr\n print("OK angr", angr.__version__)\nexcept Exception as exc:\n print("MISS angr", exc)\ntry:\n import claripy\n print("OK claripy", getattr(claripy, "__version__", "present"))\nexcept Exception as exc:\n print("MISS claripy", exc)\ntry:\n import z3\n print("OK z3", z3.get_version_string())\nexcept Exception as exc:\n print("MISS z3", exc)\nPY\n' > /usr/local/bin/pwnlab-check \
    && chmod +x /usr/local/bin/pwnlab-check

WORKDIR /work
CMD ["bash"]
