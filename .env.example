# Environment configuration for opencode-for-ctf
#
# Copy this file to .env and set the values for your system.
# Then run: node scripts/setup.mjs
#
# This will generate the platform-specific opencode.json config
# with your paths filled in.

# ============================================================
# Required
# ============================================================

# Path to the opencode-for-ctf plugin directory (the root of this repo)
# Example:
#   PLUGIN_DIR=C:\path\to\Opencode-for-CTF   (Windows)
#   PLUGIN_DIR=/home/user/Opencode-for-CTF   (Linux/Mac)
PLUGIN_DIR=

# CTF workspace directory (where your challenge files live)
# Example: C:\path\to\ctf-workspace  or  /home/user/ctf-workspace
WORKSPACE_DIR=

# Allowed roots for local file tools (platform path-delimiter separated).
# Defaults to the current project directory + worktree when unset.
# Windows: C:\ctf\workspace;C:\ctf\shared
# Linux/Mac: /home/user/ctf:/tmp/ctf
# CTF_ALLOWED_ROOTS=

# Extra hosts allowed for ctf-web-probe beyond public HTTP(S) and localhost.
# Comma-separated. Private/link-local targets must be listed explicitly.
# CTF_ALLOWED_HOSTS=10.10.10.5,lab.internal

# ============================================================
# AI Providers
# ============================================================

# DeepSeek API Key (recommended primary provider)
# https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# ============================================================
# Search & Web
# ============================================================

# Jina AI API Key — web search / scraping
# https://jina.ai/
JINA_API_KEY=

# Brave Search API Key
# https://brave.com/search/api/
BRAVE_API_KEY=

# Firecrawl API Key — web scraping
# https://www.firecrawl.dev/
FIRECRAWL_API_KEY=

# Tavily API Key — web search for AI agents
# https://tavily.com/
TAVILY_API_KEY=

# AnySearch API Key
ANYSEARCH_API_KEY=

# ============================================================
# GitHub
# ============================================================

# GitHub Personal Access Token (read-only, for code search)
# https://github.com/settings/tokens
GITHUB_PAT=

# ============================================================
# Reverse Engineering
# ============================================================

# Ghidra installation directory (for ReVa MCP)
# Example: C:\Program Files\ghidra_12.0.4_PUBLIC
GHIDRA_INSTALL_DIR=

# WireMCP launcher path (recommended Wireshark MCP backend)
# Example: C:\tools\WireMCP\server.py
# WIREMCP_LAUNCHER=

# mrexodia ida-pro-mcp is the recommended backend for the `ida-pro` MCP slot.
# Install it on PATH so `ida-pro-mcp --stdio` works from the shell.
# If you use a custom wrapper, keep it available under the same command name.

# CyberChef MCP is optional; by default the plugin assumes `npx -y cyberchef-mcp` when enabled.

# IDA Pro installation directory (optional)
# IDA_DIR=

# ============================================================
# Docker Images (optional — change if using custom CTF images)
# ============================================================

# Prefix for PWN docker images (default: pwnlab)
# CTF_PWN_IMAGE_PREFIX=pwnlab

# Pin a specific PWN docker image (overrides prefix + suffix)
# CTF_PWN_IMAGE=pwnlab:general-ubuntu22.04

# Prefix for REV docker images (default: revlab)
# CTF_REV_IMAGE_PREFIX=revlab

# ============================================================
# Proxy (optional — set if behind a corporate/great-firewall proxy)
# ============================================================

# HTTP/HTTPS proxy for curl, wget, and other network tools
# HTTP_PROXY=http://127.0.0.1:7897
# HTTPS_PROXY=http://127.0.0.1:7897

# ============================================================
# Knowledge Bases (optional — require separate deployment)
# ============================================================

# SecKB (Security Knowledge Base)
# SECKB_PYTHON=python
# SECKB_MCP_SERVER=/path/to/seckb-mcp-server.py
# SECKB_ROOT=/path/to/seckb
# SECKB_CONFIG=/path/to/seckb/config.yaml

# CVEKB (CVE Knowledge Base)
# CVEKB_MCP_SERVER=/path/to/cvekb-mcp-server.py
# CVEKB_ROOT=/path/to/cvekb
