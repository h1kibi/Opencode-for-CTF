{
  // Optional user config for opencode-for-ctf.
  // Search order (closest wins): project walk → $OPENCODE_CONFIG_DIR → ~/.config/opencode/
  // Filenames: opencode-for-ctf.jsonc | opencode-for-ctf.json

  // Default intensity for /ctf auto-routing (BINDING when mode is not forced).
  // auto = pure heuristics; fast|expert = force that lane via ctf-route-plan + /ctf hook.
  "default_mode": "auto", // auto | fast | expert

  // Disable individual runtime hooks.
  // Allowed: hashline | permission_auto_allow | chat_params | session_compacting
  //          | continuation | skill_mcp | team_events
  "disabled_hooks": [],

  "hashline": {
    "enabled": true
  },

  "continuation": {
    "enabled": true
  },

  "team_mode": {
    "enabled": true,
    "max_workers": 8
  },

  // Tool packs registered at plugin startup (restart OpenCode after changes).
  // This is the PROCESS registry (superset). ctf-fast is still filtered by allowlist.
  // Default omits rare packs: android, godot.
  // Use ["all"] for true full expert environment, or list packs explicitly.
  // "tool_packs": ["core", "web", "pwn", "rev", "crypto", "forensics", "misc", "java"],
  // "tool_packs": ["all"],
  // Optional merge into registry for expert-heavy machines:
  // "expert_tool_packs": ["android", "godot"],

  // Recommended MCP backend notes:
  // - browser uses @playwright/mcp by default.
  // - wireshark-mcp expects WIREMCP_LAUNCHER to point at WireMCP's server launcher.
  // - ida-pro expects mrexodia/ida-pro-mcp installed as `ida-pro-mcp` on PATH.
  // - cyberchef-mcp is defaulted only for crypto / forensics / misc agents.
  // - ctfd-mcp is configurable but disabled by default.

  // Example disabled MCP stubs for workspace-level opencode.jsonc:
  // "mcp": {
  //   "browser": {
  //     "type": "local",
  //     "command": ["npx", "-y", "@playwright/mcp@latest"],
  //     "enabled": false
  //   },
  //   "wireshark-mcp": {
  //     "type": "local",
  //     "command": ["python", "{env:WIREMCP_LAUNCHER}", "--stdio"],
  //     "enabled": false
  //   },
  //   "ida-pro": {
  //     "type": "local",
  //     "command": ["ida-pro-mcp", "--stdio"],
  //     "enabled": false
  //   },
  //   "cyberchef-mcp": {
  //     "type": "local",
  //     "command": ["npx", "-y", "cyberchef-mcp"],
  //     "enabled": false
  //   },
  //   "ctfd-mcp": {
  //     "type": "local",
  //     "command": ["npx", "-y", "ctfd-mcp"],
  //     "enabled": false
  //   }
  // },

  "external_skills": false
}
