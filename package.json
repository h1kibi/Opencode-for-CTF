{
  "name": "opencode-for-ctf",
  "version": "2026.07.0",
  "description": "CTF agent plugin for opencode — multi-agent orchestration, evidence-based solving, PWN/Web/Rev/Crypto/Forensics tools, knowledge base, and runtime hooks.",
  "private": true,
  "type": "module",
  "main": "./src/plugin.ts",
  "scripts": {
    "check": "tsc --noEmit && npm run check:pwn",
    "bench:web": "tsx scripts/check-web-benchmarks.ts",
    "ctf:config-qa": "node scripts/ctf-config-qa.ts",
    "ctf:config-hygiene": "node scripts/check-config-hygiene.ts",
    "ctf:command-contracts": "node scripts/check-command-helper-contracts.ts",
    "ctf:hard-regression": "node scripts/check-hard-regression.ts benchmarks/hard-regression",
    "ctf:evidence-init": "node scripts/init-ctf-evidence.ts",
    "ctf:write-evidence": "node scripts/write-evidence-state.ts",
    "ctf:read-evidence": "node scripts/read-evidence-state.ts",
    "ctf:evidence-doctor": "node scripts/ctf-evidence-doctor.ts",
    "ctf:resume-helper": "node scripts/resume-helper.ts",
    "ctf:snapshot-helper": "node scripts/snapshot-helper.ts",
    "ctf:write-route": "node scripts/write-route-state.ts",
    "ctf:write-primitive": "node scripts/write-primitive-state.ts",
    "ctf:write-closure": "node scripts/write-closure-state.ts",
    "ctf:rev-team-init": "node scripts/init-rev-team-memory.ts",
    "ctf:rev-team-read": "node scripts/read-rev-team-memory.ts",
    "ctf:rev-team-update": "node scripts/update-rev-team-memory.ts",
    "lint": "tsc --noEmit",
    "check:pwn": "tsx scripts/pwn-smoke-check.ts",
    "check:tool-bugs": "tsx scripts/check-tool-bug-regressions.ts",
    "check:pwn-retrieval": "tsx scripts/check-pwn-retrieval-frontline.ts",
    "check:pwn-skill-local": "tsx scripts/check-pwn-skill-repo-local.ts",
    "check:pwn-cards-local": "tsx scripts/check-pwn-pattern-cards-local.ts",
    "list": "git ls-files tools skills commands packages rules scripts",
    "doctor": "tsx scripts/doctor.ts",
    "doctor:android-rev": "tsx scripts/doctor-android-rev.ts",
    "doctor:revlab": "tsx scripts/doctor-revlab.ts",
    "doctor:go-rev": "tsx scripts/doctor-go-rev.ts",
    "doctor:rev": "tsx scripts/doctor-rev.ts",
    "doctor:godot-rev": "tsx scripts/doctor-godot-rev.ts",
    "doctor:image-ocr": "tsx scripts/doctor-image-ocr.ts",
    "check:rev-android": "tsx scripts/check-rev-android-readiness.ts",
    "state:print": "tsx scripts/print-ctf-state.ts",
    "tools:verify": "tsx scripts/verify-ctf-tooling.ts"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.17.0",
    "@opencode-ai/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.20.0",
    "typescript": "^6.0.3"
  },
  "opencode": {
    "type": "plugin",
    "description": "CTF agent ecosystem plugin. Provides runtime hooks (continuation, team-mode, skill MCP lifecycle) plus skills, tools, commands, and agents for CTF solving.",
    "provides": [
      "runtime-hooks",
      "ctf-agents",
      "ctf-skills",
      "ctf-tools",
      "ctf-commands"
    ]
  }
}
