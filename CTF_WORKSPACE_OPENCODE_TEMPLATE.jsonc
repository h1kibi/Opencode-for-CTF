{
  "$schema": "https://opencode.ai/config.json",

  // Copy this file into your CTF workspace as either:
  //   <workspace>/opencode.jsonc
  //   <workspace>/.opencode/opencode.jsonc
  // Examples:
  //   Windows: C:\path\to\ctf-workspace\opencode.jsonc
  //   Linux/macOS: /path/to/ctf-workspace/opencode.jsonc
  // Then start OpenCode from that workspace directory.
  //
  // Recommended per-challenge layout:
  //   work/<challenge-id>/
  //     evidence.json
  //     endpoint-matrix.md
  //     state-diff.md
  //     primitive-ledger.json
  //     flag-location.json
  //     blocked-hypotheses.json
  //     closure-queue.json
  //     .ctf-decision-state.json
  //     .ctf-chain-state.json
  //     solve.py
  //     retro.md
  // Use one directory per challenge so mixed evidence and stale probes do not
  // pollute later solves.

  "default_agent": "ctf-fast", // optional: ctf-fast | ctf-expert
  "snapshot": false,
  "small_model": "deepseek/deepseek-v4-flash",

  "tool_output": {
    "max_lines": 180,
    "max_bytes": 9000
  },

  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 2,
    "reserved": 7000
  },

  "mcp": {
    "browser": { "enabled": false },
    "brave_search": { "enabled": false },
    "markitdown": { "enabled": false },
    "obsidian": { "enabled": false },
    "filesystem": { "enabled": false },
    "github": { "enabled": false },
    "context7": { "enabled": false },
    "gh_grep": { "enabled": false },
    "jina": { "enabled": false },
    "firecrawl": { "enabled": false },
    "tavily": { "enabled": false },
    "playwright": { "enabled": false },
    "puppeteer": { "enabled": false }
  },

  "watcher": {
    "ignore": [
      "**/archive/**",
      "**/artifacts/**",
      "**/extracted/**",
      "**/work/**",
      "**/work/*/extracted/**",
      "**/work/*/artifacts/**",
      "**/work/*/.ctf-decision-state.json",
      "**/work/*/.ctf-chain-state.json",
      "**/*.pcap",
      "**/*.pcapng",
      "**/*.mem",
      "**/*.raw",
      "**/*.img",
      "**/*.iso",
      "**/*.zip",
      "**/*.7z",
      "**/*.tar",
      "**/*.gz",
      "**/node_modules/**",
      "**/.git/**"
    ]
  }
}
