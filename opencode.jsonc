{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "puppeteer": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-puppeteer"
      ],
      "environment": {
        "PUPPETEER_EXECUTABLE_PATH": "C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe"
      },
      "enabled": true,
      "timeout": 30000
    },
    "ReVa": {
      "type": "local",
      "command": [
        "mcp-reva"
      ],
      "environment": {
        "GHIDRA_INSTALL_DIR": "C:\\Program Files\\ghidra_12.0.4_PUBLIC"
      },
      "enabled": false,
      "timeout": 60000
    },
    "ida-pro": {
      "type": "local",
      "command": [
        "python",
        "-m",
        "ida_pro_mcp"
      ],
      "environment": {
        "IDA_PATH": "C:\\Tools\\IDA Professional 9.2"
      },
      "enabled": false,
      "timeout": 60000
    },
    "radare2": {
      "type": "local",
      "command": [
        "python",
        "C:\\Tools\\Agent\\security_mcp_wrappers.py",
        "radare2"
      ],
      "enabled": false,
      "timeout": 30000
    },
    "git": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@cyanheads/git-mcp-server"
      ],
      "enabled": true,
      "timeout": 30000
    },
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "C:\\\\Tools\\\\Agent\\\\ctf-workspace"
      ],
      "enabled": true
    },
    "vmprotect": {
      "type": "local",
      "command": [
        "python",
        "C:\\Users\\Administrator\\vmprotect_mcp.py"
      ],
      "enabled": false,
      "timeout": 30000
    },
    "shodan": {
      "type": "local",
      "command": [
        "python",
        "C:\\Tools\\Agent\\security_mcp_wrappers.py",
        "shodan"
      ],
      "environment": {
        "SHODAN_API_KEY": "${SHODAN_API_KEY}"
      },
      "enabled": false,
      "timeout": 30000
    },
    "frida": {
      "type": "local",
      "command": [
        "python",
        "-m",
        "frida_mcp.cli"
      ],
      "enabled": false,
      "timeout": 30000
    },
    "jadx": {
      "type": "local",
      "command": [
        "python",
        "C:\\Tools\\Agent\\security_mcp_wrappers.py",
        "jadx"
      ],
      "enabled": false,
      "timeout": 30000
    },
    "volatility": {
      "type": "local",
      "command": [
        "python",
        "C:\\Tools\\Agent\\security_mcp_wrappers.py",
        "volatility"
      ],
      "enabled": false,
      "timeout": 60000
    },
    "yara": {
      "type": "local",
      "command": [
        "python",
        "C:\\Tools\\Agent\\security_mcp_wrappers.py",
        "yara"
      ],
      "enabled": false,
      "timeout": 30000
    },
    "nmap": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@ebowwa/mcp-nmap"
      ],
      "enabled": false,
      "timeout": 60000
    }
  },
  "tool_output": {
    "max_lines": 800,
    "max_bytes": 30000
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 4,
    "reserved": 10000
  },
  "plugin": [
    "opencode-shell-strategy"
  ],
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "edit": {
      "*": "ask",
      "notes.md": "allow",
      "solve.py": "allow",
      "solve.js": "allow",
      "exploit.py": "allow",
      "agent_flag.txt": "allow"
    },
    "bash": {
      "*": "ask",
      "python *": "allow",
      "python3 *": "allow",
      "node *": "allow",
      "file *": "allow",
      "strings *": "allow",
      "xxd *": "allow",
      "readelf *": "allow",
      "objdump *": "allow",
      "checksec *": "allow",
      "curl http://127.0.0.1*": "allow",
      "curl http://localhost*": "allow",
      "nc 127.0.0.1*": "ask",
      "nc localhost*": "ask",
      "docker ps*": "allow",
      "docker logs*": "allow",
      "docker compose up*": "ask",
      "docker compose down*": "ask",
      "gdb *": "ask",
      "sage *": "ask",
      "openssl *": "ask",
      "rm -rf *": "deny",
      "ssh *": "deny",
      "scp *": "deny",
      "rm *": "deny",
      "del *": "deny",
      "rmdir *": "deny",
      "Remove-Item *": "deny",
      "powershell Remove-Item *": "deny",
      "pwsh Remove-Item *": "deny"
    },
    "webfetch": "ask",
    "websearch": "deny",
    "skill": {
      "*": "ask",
      "ctf-*": "allow"
    },
    "shodan_*": "deny",
    "navicat_*": "deny",
    "nmap_*": "ask",
    "mysql_*": "ask",
    "puppeteer_*": "ask",
    "playwright_*": "ask",
    "ida-pro_*": "ask",
    "radare2_*": "ask",
    "jadx_*": "ask",
    "frida_*": "ask",
    "ReVa_*": "ask",
    "vmprotect_*": "ask",
    "volatility_*": "ask",
    "yara_*": "ask",
    "word_*": "ask",
    "external_directory": {
      "*": "deny",
      "C:\\\\Tools\\\\Agent\\\\ctf-workspace": "allow",
      "C:\\\\Tools\\\\Agent\\\\ctf-workspace\\\\**": "allow",
      "C:/Tools/Agent/ctf-workspace": "allow",
      "C:/Tools/Agent/ctf-workspace/**": "allow"
    }
  },
  "agent": {
    "ctf-web": {
      "description": "Solve authorized Web CTF challenges using source review, browser interaction, HTTP probing, local reproduction, and exploit scripting.",
      "mode": "primary",
      "temperature": 0.1,
      "steps": 80,
      "permission": {
        "websearch": "deny",
        "webfetch": "ask",
        "bash": {
          "*": "ask",
          "python *": "allow",
          "python3 *": "allow",
          "node *": "allow",
          "npm test*": "allow",
          "pytest *": "allow",
          "curl http://127.0.0.1*": "allow",
          "curl http://localhost*": "allow",
          "docker ps*": "allow",
          "docker logs*": "allow",
          "docker compose up*": "ask",
          "docker compose down*": "ask",
          "nmap 127.0.0.1*": "ask",
          "nmap localhost*": "ask",
          "rm -rf *": "deny",
          "ssh *": "deny",
          "scp *": "deny",
          "rm *": "deny",
          "del *": "deny",
          "rmdir *": "deny",
          "Remove-Item *": "deny",
          "powershell Remove-Item *": "deny",
          "pwsh Remove-Item *": "deny"
        },
        "edit": {
          "*": "ask",
          "notes.md": "allow",
          "solve.py": "allow",
          "solve.js": "allow",
          "agent_flag.txt": "allow"
        },
        "skill": {
          "*": "ask",
          "ctf-*": "allow"
        },
        "filesystem_*": "ask",
        "git_*": "ask",
        "puppeteer_*": "ask",
        "playwright_*": "ask",
        "mysql_*": "ask",
        "nmap_*": "ask",
        "shodan_*": "deny",
        "ida-pro_*": "deny",
        "radare2_*": "deny",
        "jadx_*": "deny",
        "frida_*": "deny",
        "ReVa_*": "deny",
        "vmprotect_*": "deny",
        "volatility_*": "deny",
        "yara_*": "deny",
        "word_*": "deny"
      },
      "prompt": "You are a legal CTF Web challenge solver. Work only on authorized local, lab, or CTF targets. Use the relevant ctf-* skill when available. Keep notes.md, map routes and inputs, identify likely bug classes, test minimal payloads, write reproducible solve.py or solve.js, and write the verified final flag to agent_flag.txt."
    },
    "ctf-pwn": {
      "description": "Solve authorized binary exploitation CTF challenges using local analysis, debugging, exploit development, and pwntools scripts.",
      "mode": "primary",
      "temperature": 0.1,
