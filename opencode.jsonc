{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "puppeteer": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-puppeteer"
      ],
      "environment": {
        "PUPPETEER_EXECUTABLE_PATH": "{env:PUPPETEER_EXECUTABLE_PATH}"
      },
      "enabled": false,
      "timeout": 30000
    },
    "ReVa": {
      "type": "local",
      "command": [
        "mcp-reva"
      ],
      "environment": {
        "GHIDRA_INSTALL_DIR": "{env:GHIDRA_INSTALL_DIR}"
      },
      "enabled": false,
      "timeout": 60000
    },
    "ida-pro": {
      "type": "local",
      "command": [
        "python",
        "-m",
        "ida_pro_mcp"
      ],
      "environment": {
        "IDA_PATH": "{env:IDA_PATH}"
      },
      "enabled": false,
      "timeout": 60000
    },
    "radare2": {
      "type": "local",
      "command": [
        "python",
        "{env:SECURITY_MCP_WRAPPERS}",
        "radare2"
      ],
      "enabled": false,
      "timeout": 30000
    },
    "git": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@cyanheads/git-mcp-server"
      ],
      "enabled": false,
      "timeout": 30000
    },
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "{env:CTF_WORKSPACE}"
      ],
      "enabled": false
    },
    "vmprotect": {
      "type": "local",
      "command": [
        "python",
        "{env:VMPROTECT_MCP}"
      ],
      "enabled": false,
      "timeout": 30000
    },
    "shodan": {
      "type": "local",
      "command": [
        "python",
        "{env:SECURITY_MCP_WRAPPERS}",
        "shodan"
      ],
      "environment": {
        "SHODAN_API_KEY": "{env:SHODAN_API_KEY}"
      },
      "enabled": false,
      "timeout": 30000
    },
    "frida": {
      "type": "local",
      "command": [
        "python",
        "-m",
        "frida_mcp.cli"
      ],
      "enabled": false,
      "timeout": 30000
    },
    "jadx": {
      "type": "local",
      "command": [
        "python",
        "{env:SECURITY_MCP_WRAPPERS}",
        "jadx"
      ],
      "enabled": false,
      "timeout": 30000
    },
    "volatility": {
      "type": "local",
      "command": [
        "python",
        "{env:SECURITY_MCP_WRAPPERS}",
        "volatility"
      ],
      "enabled": false,
      "timeout": 60000
    },
    "yara": {
      "type": "local",
      "command": [
        "python",
        "{env:SECURITY_MCP_WRAPPERS}",
        "yara"
      ],
      "enabled": false,
      "timeout": 30000
    },
    "nmap": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@ebowwa/mcp-nmap"
      ],
      "enabled": false,
      "timeout": 60000
    },
    "chrome": {
      "type": "remote",
      "url": "http://127.0.0.1:12306/mcp",
      "enabled": false,
      "timeout": 30000
    }
  },
  "tool_output": {
    "max_lines": 800,
    "max_bytes": 30000
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 4,
    "reserved": 10000
  },
  "plugin": [],
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "list": {
      "*": "allow"
    },
    "glob": {
      "*": "allow"
    },
    "grep": {
      "*": "allow"
    },
    "edit": {
      "*": "ask",
      "notes.md": "allow",
      "solve.py": "allow",
      "solve.js": "allow",
      "exploit.py": "allow",
      "agent_flag.txt": "allow"
    },
    "bash": {
      "*": "ask",
      "python *": "allow",
      "python3 *": "allow",
      "node *": "allow",
      "file *": "allow",
      "strings *": "allow",
      "xxd *": "allow",
      "readelf *": "allow",
      "objdump *": "allow",
      "checksec *": "allow",
      "curl http://127.0.0.1*": "allow",
      "curl http://localhost*": "allow",
      "nc 127.0.0.1*": "ask",
      "nc localhost*": "ask",
      "docker ps*": "allow",
      "docker logs*": "allow",
      "docker compose up*": "ask",
      "docker compose down*": "ask",
      "gdb *": "ask",
      "sage *": "ask",
      "openssl *": "ask",
          "rm -rf *": "deny",
          "ssh *": "deny",
          "scp *": "deny",
          "rm *": "deny",
          "del *": "deny",
          "rmdir *": "deny",
          "Remove-Item *": "deny",
          "powershell Remove-Item *": "deny",
          "pwsh Remove-Item *": "deny",
          "ffuf *": "ask",
          "gobuster *": "ask",
          "feroxbuster *": "ask",
          "dirsearch *": "ask",
          "wfuzz *": "ask",
          "sqlmap *": "ask",
          "hydra *": "deny",
          "ab *": "ask",
          "hey *": "ask"
    },
    "webfetch": "ask",
    "websearch": "deny",
    "skill": {
      "*": "ask",
      "ctf-*": "allow"
    },
    "ctf-file-triage": "allow",
    "ctf-flag-grep": "allow",
    "ctf-rsa-probe": "allow",
    "ctf-web-probe": "ask",
    "ctf-java-map": "allow",
    "ctf-api-map": "allow",
    "ctf-file-write-matrix": "allow",
    "shodan_*": "deny",
    "navicat_*": "deny",
    "nmap_*": "ask",
    "mysql_*": "ask",
    "puppeteer_*": "ask",
    "chrome_*": "ask",
    "chrome_get_web_content": "allow",
    "chrome_get_interactive_elements": "allow",
    "chrome_history": "deny",
    "chrome_bookmark_search": "deny",
    "chrome_bookmark_add": "deny",
    "chrome_bookmark_delete": "deny",
    "chrome_chrome_get_web_content": "allow",
    "chrome_chrome_get_interactive_elements": "allow",
    "chrome_chrome_history": "deny",
    "chrome_chrome_bookmark_search": "deny",
    "chrome_chrome_bookmark_add": "deny",
    "chrome_chrome_bookmark_delete": "deny",
    "chrome_chrome_*": "ask",
    "ida-pro_*": "ask",
    "radare2_*": "ask",
    "jadx_*": "ask",
    "frida_*": "ask",
    "ReVa_*": "ask",
    "vmprotect_*": "ask",
    "volatility_*": "ask",
    "yara_*": "ask",
    "word_*": "ask",
    "external_directory": {
      "*": "deny",
      "C:\\Tools\\Agent\\ctf-workspace": "allow",
      "C:\\Tools\\Agent\\ctf-workspace\\**": "allow",
      "C:/Tools/Agent/ctf-workspace": "allow",
      "C:/Tools/Agent/ctf-workspace/**": "allow"
    }
  },
  "default_agent": "ctf-router",
  "agent": {
    "ctf-router": {
      "description": "Route authorized CTF challenges to the best specialized solver using low-cost triage and evidence-weighted category scoring.",
      "mode": "primary",
      "temperature": 0.1,
      "steps": 25,
      "permission": {
        "read": "allow",
        "list": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "ask",
        "websearch": "deny",
        "bash": {
          "*": "ask",
          "file *": "allow",
          "strings *": "allow",
          "xxd *": "allow",
          "python *": "allow",
          "python3 *": "allow",
          "docker ps*": "allow",
          "docker logs*": "allow",
          "rm -rf *": "deny",
          "ssh *": "deny",
          "scp *": "deny",
          "rm *": "deny",
          "del *": "deny",
          "rmdir *": "deny",
          "Remove-Item *": "deny",
          "powershell Remove-Item *": "deny",
          "pwsh Remove-Item *": "deny"
        },
        "edit": {
          "*": "ask",
          "notes.md": "allow"
        },
        "skill": {
          "*": "ask",
          "ctf-*": "allow"
        },
        "ctf-file-triage": "allow",
        "ctf-flag-grep": "allow",
        "ctf-rsa-probe": "allow",
        "ctf-web-probe": "ask",
        "task": {
          "*": "ask",
          "ctf-web": "allow",
          "ctf-pwn": "allow",
          "ctf-rev": "allow",
          "ctf-crypto": "allow",
          "ctf-forensics": "allow",
          "ctf-misc": "allow"
        },
        "puppeteer_*": "deny",
        "chrome_*": "deny",
        "nmap_*": "ask",
        "filesystem_*": "ask",
        "git_*": "deny",
        "shodan_*": "deny",
        "ida-pro_*": "deny",
        "radare2_*": "deny",
        "jadx_*": "deny",
        "frida_*": "deny",
        "ReVa_*": "deny",
        "vmprotect_*": "deny",
        "volatility_*": "deny",
        "yara_*": "deny",
        "word_*": "deny"
      },
      "prompt": "You are a route-only CTF planner for authorized CTF, lab, benchmark, and local challenge targets. Start with ctf-router and ctf-common when useful. Inventory files, services, target scope, and flag format; run only low-cost triage; build an evidence-weighted category table; choose exactly one next specialized CTF agent or command. If a local artifact path is provided, call ctf-file-triage before selecting a final category unless the challenge statement alone is decisive. Prefer ctf-rsa-probe for RSA-like inputs, ctf-web-probe only on authorized or local challenge URLs, and ctf-flag-grep before claiming unsolved. Do not deeply exploit unless the challenge is trivial. Keep notes.md updated and never guess flags."
    },
    "ctf-web": {
      "description": "Solve authorized Web CTF challenges using source review, browser interaction, HTTP probing, local reproduction, and exploit scripting.",
      "mode": "all",
      "temperature": 0.1,
      "steps": 80,
      "permission": {
        "websearch": "deny",
        "webfetch": "ask",
        "bash": {
          "*": "ask",
          "python *": "allow",
          "python3 *": "allow",
          "node *": "allow",
          "npm test*": "allow",
          "pytest *": "allow",
          "curl http://127.0.0.1*": "allow",
          "curl http://localhost*": "allow",
          "docker ps*": "allow",
          "docker logs*": "allow",
          "docker compose up*": "ask",
          "docker compose down*": "ask",
          "nmap 127.0.0.1*": "ask",
          "nmap localhost*": "ask",
          "rm -rf *": "deny",
          "ssh *": "deny",
          "scp *": "deny",
          "rm *": "deny",
          "del *": "deny",
          "rmdir *": "deny",
          "Remove-Item *": "deny",
          "powershell Remove-Item *": "deny",
          "pwsh Remove-Item *": "deny",
          "ffuf *": "ask",
          "gobuster *": "ask",
          "feroxbuster *": "ask",
          "dirsearch *": "ask",
          "wfuzz *": "ask",
          "sqlmap *": "ask",
          "hydra *": "deny",
          "ab *": "ask",
          "hey *": "ask"
        },
        "edit": {
          "*": "ask",
          "notes.md": "allow",
          "solve.py": "allow",
          "solve.js": "allow",
          "agent_flag.txt": "allow",
          "retros/*.md": "allow",
          "lessons/*.md": "allow",
          "patches/*.md": "allow"
        },
        "skill": {
          "*": "ask",
          "ctf-*": "allow"
        },
        "filesystem_*": "ask",
        "git_*": "ask",
        "puppeteer_*": "ask",
        "chrome_*": "ask",
        "chrome_get_web_content": "allow",
        "chrome_get_interactive_elements": "allow",
        "chrome_history": "deny",
        "chrome_bookmark_search": "deny",
        "chrome_bookmark_add": "deny",
        "chrome_bookmark_delete": "deny",
        "chrome_chrome_get_web_content": "allow",
        "chrome_chrome_get_interactive_elements": "allow",
        "chrome_chrome_history": "deny",
        "chrome_chrome_bookmark_search": "deny",
        "chrome_chrome_bookmark_add": "deny",
        "chrome_chrome_bookmark_delete": "deny",
        "chrome_chrome_*": "ask",
        "mysql_*": "ask",
        "nmap_*": "ask",
        "ctf-web-probe": "allow",
        "ctf-java-map": "allow",
        "ctf-api-map": "allow",
        "ctf-file-write-matrix": "allow",
        "shodan_*": "deny",
        "ida-pro_*": "deny",
        "radare2_*": "deny",
        "jadx_*": "deny",
        "frida_*": "deny",
        "ReVa_*": "deny",
        "vmprotect_*": "deny",
        "volatility_*": "deny",
        "yara_*": "deny",
        "word_*": "deny"
      },
      "prompt": "You are a legal CTF Web challenge solver. Work only on authorized local, lab, or CTF targets. Use ctf-common and ctf-web. Start in recon phase: map routes, inputs, auth/session boundaries, source/sink behavior, debug/admin/upload/editor surfaces, and bot behavior before deeply exploiting any one bug class. Build an attack queue ranked by value, verification cost, risk, stability, and confidence; do not pursue the first visible vulnerability just because it appears first. Prefer high-value, low-cost, low-risk, source-backed checks. Maintain a compact Primitive Ledger in notes.md once non-trivial behavior appears. Once one critical primitive or two high primitives are confirmed, stop broad probing and build the shortest stable exploit chain. Prefer admin sessions, backend endpoints, database-backed fields, reloadable/imported files, and debug/log views over blind callbacks or new routes. Before destructive, batch, high-concurrency, repeated bot-triggering, upload/write/overwrite, or state-changing actions, run a low-risk canary, record the risk plan, and obey a strict attempt budget. Write reproducible solve.py or solve.js and write only the verified final flag to agent_flag.txt."
    },
    "ctf-pwn": {
      "description": "Solve authorized binary exploitation CTF challenges using local analysis, debugging, exploit development, and pwntools scripts.",
      "mode": "all",
      "temperature": 0.1,
      "steps": 100,
      "permission": {
        "webfetch": "deny",
