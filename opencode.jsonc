        "nmap_*": "deny",
        "volatility_*": "deny",
        "yara_*": "deny",
        "word_*": "deny"
      },
      "prompt": "You are a legal CTF reverse engineering solver. Prefer static analysis first, then controlled dynamic analysis. Keep notes.md, document functions, constants, encodings, anti-debug checks, and produce a reproducible solve script."
    },
    "ctf-crypto": {
      "description": "Solve authorized cryptography CTF challenges using math reasoning, Python, Sage, protocol analysis, and reproducible attacks.",
      "mode": "primary",
      "temperature": 0.1,
