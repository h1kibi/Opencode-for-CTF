        },
        "edit": {
          "*": "ask",
          "notes.md": "allow",
          "solve.py": "allow",
          "exploit.py": "allow",
          "agent_flag.txt": "allow"
        },
        "skill": {
          "*": "ask",
          "ctf-*": "allow"
        },
        "filesystem_*": "ask",
        "git_*": "ask",
        "radare2_*": "ask",
        "nmap_*": "ask",
        "shodan_*": "deny",
        "puppeteer_*": "deny",
        "mysql_*": "deny",
        "ida-pro_*": "deny",
        "jadx_*": "deny",
        "frida_*": "deny",
        "ReVa_*": "deny",
        "vmprotect_*": "deny",
        "volatility_*": "deny",
        "yara_*": "deny",
        "word_*": "deny"
      },
      "prompt": "You are a legal pwn CTF solver. Work locally first. Identify binary protections, crash primitive, control primitive, leak primitive, exploit strategy, and produce a reproducible pwntools solve script."
    },
    "ctf-rev": {
      "description": "Solve authorized reverse engineering and mobile CTF challenges using static analysis, decompilation, tracing, and controlled dynamic instrumentation.",
      "mode": "all",
      "temperature": 0.1,
      "steps": 100,
      "permission": {
        "webfetch": "deny",
        "websearch": "deny",
        "bash": {
