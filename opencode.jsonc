{
  "$schema": "https://opencode.ai/config.json",

  // Source-checkout configuration.
  //
  // This file is intentionally minimal because OpenCode automatically loads
  // opencode.jsonc from the current project. Machine-specific paths, provider
  // credentials, and optional MCP definitions must not live here.
  //
  // Recommended installation:
  //   npm run ctf:install
  //
  // The installer safely adds the built plugin, agents, commands, skills, and
  // rules to the user's OpenCode configuration. Optional MCP profiles remain
  // disabled until explicitly reviewed and enabled.

  "share": "disabled",

  "keybinds": {
    "leader": "ctrl+x",
    "agent_cycle": "tab,<leader>j",
    "agent_cycle_reverse": "shift+tab,<leader>k",
    "agent_list": "<leader>a"
  },

  // Managed installation registers the built plugin path. Keep this empty in
  // the source checkout to avoid a machine-specific absolute path.
  "plugin": [],

  "permission": {
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git branch*": "allow",
      "rm *": "deny",
      "Remove-Item *": "deny",
      "del *": "deny"
    },
    "edit": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "**/.ssh/**": "deny",
      "**/.aws/**": "deny",
      "**/.azure/**": "deny",
      "**/.gcloud/**": "deny",
      "**/.kube/**": "deny",
      "**/.gnupg/**": "deny"
    },
    "webfetch": "ask",
    "websearch": "ask"
  },

  "tool_output": {
    "max_lines": 500,
    "max_bytes": 30000
  },

  "compaction": {
    "auto": true,
    "prune": false,
    "tail_turns": 40,
    "reserved": 12000
  },

  "watcher": {
    "ignore": [
      "**/extracted/**",
      "**/work/**",
      "**/*.pcap",
      "**/*.pcapng",
      "**/*.mem",
      "**/*.raw",
      "**/*.img",
      "**/*.iso",
      "**/*.zip",
      "**/*.7z",
      "**/*.tar",
      "**/*.gz",
      "**/*.bin",
      "**/*.elf",
      "**/*.exe",
      "**/*.dll",
      "**/*.so",
      "**/*.apk",
      "**/*.dex",
      "**/node_modules/**",
      "**/.git/**"
    ]
  }
}
