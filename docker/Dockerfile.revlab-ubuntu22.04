FROM ubuntu:22.04

# CTF rev/forensics 专用镜像
# 预装: tshark / capinfos / file / strings / binwalk / upx / xxd
# binutils / readelf / objdump / nm / gdb / strace / ltrace
# radare2 / rizin
# python3 + pycryptodome + scapy + pwntools + capstone + unicorn + z3 + angr
# golang toolchain (go tool nm / objdump)
# 同时附 revlab-check 健康检查脚本
#
# Build args (mirror 加速,所有都可选):
#   APT_MIRROR        e.g. http://mirrors.tuna.tsinghua.edu.cn/ubuntu/
#   APT_SECURITY      e.g. http://mirrors.tuna.tsinghua.edu.cn/ubuntu-security/
#   PIP_INDEX_URL     e.g. https://pypi.tuna.tsinghua.edu.cn/simple
#   PIP_TRUSTED_HOST  e.g. pypi.tuna.tsinghua.edu.cn
#   GOPROXY           e.g. https://goproxy.cn,direct
#
# 示例:
#   docker build \
#     --build-arg APT_MIRROR=http://mirrors.tuna.tsinghua.edu.cn/ubuntu/ \
#     --build-arg PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple \
#     --build-arg PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn \
#     --build-arg GOPROXY=https://goproxy.cn,direct \
#     -t revlab:ubuntu22.04 \
#     -f Dockerfile.revlab-ubuntu22.04 .

ARG APT_MIRROR=""
ARG APT_SECURITY=""
ARG PIP_INDEX_URL=""
ARG PIP_TRUSTED_HOST=""
ARG GOPROXY=""

ENV DEBIAN_FRONTEND=noninteractive \
    TZ=Etc/UTC \
    LC_ALL=C.UTF-8 \
    LANG=C.UTF-8 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    GOFLAGS=-mod=mod \
    GOPATH=/root/go \
    PATH=/usr/local/go/bin:/root/go/bin:${PATH}

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

# 可选:替换 apt 镜像源(用 # 作 sed 分隔符,避免与 ERE alternation | 冲突)
RUN if [ -n "$APT_MIRROR" ]; then \
      sed -i -E "s#http://(archive|cn\.archive|security)\.ubuntu\.com/ubuntu/?#${APT_MIRROR}#g" /etc/apt/sources.list || true; \
      if [ -n "$APT_SECURITY" ]; then \
        sed -i -E "s#http://security\.ubuntu\.com/ubuntu/?#${APT_SECURITY}#g" /etc/apt/sources.list || true; \
      fi; \
      echo "==> using apt mirror: $APT_MIRROR"; \
      head -n 5 /etc/apt/sources.list || true; \
    fi

RUN dpkg --add-architecture i386 \
    && sed -i -E 's/(jammy[^ ]*[[:space:]]+)main restricted/\1main restricted universe multiverse/g; s/(jammy[^ ]*[[:space:]]+)main$/\1main universe multiverse/g' /etc/apt/sources.list || true \
    && apt-get -o Acquire::Retries=5 -o Acquire::http::Timeout=30 update \
    && apt-get -o Acquire::Retries=5 -o Acquire::http::Timeout=30 install -y --no-install-recommends --fix-missing \
      apt-transport-https \
      binutils \
      binutils-multiarch \
      bsdmainutils \
      build-essential \
      ca-certificates \
      libcap2-bin \
      checksec \
      clang \
      cmake \
      coreutils \
      curl \
      dnsutils \
      elfutils \
      file \
      g++-multilib \
      gcc-multilib \
      gdb \
      gdb-multiarch \
      gdbserver \
      git \
      git-lfs \
      gnupg \
      golang-go \
      hexedit \
      iproute2 \
      iputils-ping \
      jq \
      less \
      libcapstone-dev \
      libffi-dev \
      libglib2.0-dev \
      libpcap-dev \
      libseccomp-dev \
      libssl-dev \
      ltrace \
      make \
      nasm \
      netcat-openbsd \
      net-tools \
      openssh-client \
      patchelf \
      pkg-config \
      procps \
      python3 \
      python3-dev \
      python3-pip \
      python3-setuptools \
      python3-venv \
      ripgrep \
      socat \
      strace \
      sudo \
      tcpdump \
      tshark \
      unzip \
      upx-ucl \
      vim \
      wget \
      xxd \
      zip \
      zlib1g-dev \
    && rm -rf /var/lib/apt/lists/*

# === v2 升级:覆盖 95%+ Linux REV 主流任务 ===
# 每条 RUN 独立 + WARN fallback,单工具失败不阻塞其他工具

# radare2 (apt 无候选包时用 git clone + sys/install.sh 编译,~3 min)
RUN set +e; \
    if ! command -v r2 >/dev/null 2>&1; then \
      apt-get update; \
      apt-get install -y --no-install-recommends radare2; \
      if [ $? -ne 0 ]; then \
        echo "==> apt radare2 failed, trying git build (3-5 min)"; \
        git clone --depth=1 https://github.com/radareorg/radare2 /tmp/r2 && \
        cd /tmp/r2 && sys/install.sh && \
        if [ -x /tmp/r2/binr/radare2/radare2 ]; then \
          install -m 0755 /tmp/r2/binr/radare2/radare2 /usr/local/bin/radare2 && \
          ln -sf /usr/local/bin/radare2 /usr/local/bin/r2; \
        fi && \
        rm -rf /tmp/r2; \
      fi; \
      rm -rf /var/lib/apt/lists/*; \
    fi; \
    command -v r2 && r2 -v | head -1 || echo "WARN: radare2 not installed (rizin/lief/IDA still available)"

# rizin: Ubuntu 22.04 官方仓库通常无包,优先尝试 RizinOrg 的 OBS 仓库
RUN set +e; \
    if ! command -v rizin >/dev/null 2>&1; then \
      curl -fsSL https://cdn.opensuse.org/repositories/home:/RizinOrg/xUbuntu_22.04/Release.key -o /tmp/rizin.key && \
      gpg --dearmor < /tmp/rizin.key > /usr/share/keyrings/rizin.gpg && \
      echo 'deb [signed-by=/usr/share/keyrings/rizin.gpg] https://cdn.opensuse.org/repositories/home:/RizinOrg/xUbuntu_22.04/ /' > /etc/apt/sources.list.d/rizin.list && \
      apt-get update && \
      apt-get install -y --no-install-recommends rizin && \
      rm -f /tmp/rizin.key; \
      rm -rf /var/lib/apt/lists/*; \
    fi; \
    command -v rizin && rizin -v | head -1 || echo "WARN: rizin not installed (radare2 remains available)"

# qemu-user-static + binfmt-support:跨架构运行 aarch64/mips/riscv 静态二进制
RUN apt-get update \
    && apt-get install -y --no-install-recommends qemu-user-static binfmt-support \
    && rm -rf /var/lib/apt/lists/* \
    && (qemu-aarch64-static --version | head -1 || true) \
    && (qemu-mips-static --version | head -1 || true) \
    && (qemu-riscv64-static --version | head -1 || true) \
    || echo "WARN: qemu-user-static install partially failed"

# Ruby + one_gadget + seccomp-tools:PWN/REV 共用
RUN apt-get update \
    && apt-get install -y --no-install-recommends ruby ruby-dev \
    && rm -rf /var/lib/apt/lists/* \
    && (gem install one_gadget seccomp-tools || echo "WARN: gem install failed") \
    && (one_gadget --help 2>&1 | head -1 || true) \
    || echo "WARN: ruby toolchain install issue"

# Python bytecode 反编译(uncompyle6 支持 2.7,decompyle3 支持 3.7-3.8,xdis 通用 dis)
RUN python3 -m pip install uncompyle6 decompyle3 xdis \
    && python3 -c "import uncompyle6, decompyle3, xdis; print('pyc decompiler OK')" \
    || echo "WARN: python bytecode decompiler install failed"

# Qiling:全系统模拟(syscall + libc auto-stub)
RUN python3 -m pip install qiling \
    && python3 -c "import qiling; print('qiling', qiling.__version__)" \
    || echo "WARN: qiling install failed (heavy dep, may need network)"

# wabt:WASM 工具集(wasm-objdump / wasm2wat / wasm2c)
RUN apt-get update \
    && apt-get install -y --no-install-recommends wabt \
    && rm -rf /var/lib/apt/lists/* \
    && (wasm-objdump --version 2>&1 | head -1 || true) \
    || echo "WARN: wabt install failed"

# GoReSym:Go 强符号恢复(剥离的 Go binary,比 go tool nm 更全)
RUN (go install github.com/mandiant/GoReSym@latest 2>&1 || true) \
    && (ls /root/go/bin/GoReSym 2>/dev/null && /root/go/bin/GoReSym --help 2>&1 | head -1 || true) \
    || echo "WARN: GoReSym install failed (go1.18 should work)"

# Android APK 自包含工具(不依赖 host:apktool/aapt 在容器内可用)
RUN apt-get update \
    && apt-get install -y --no-install-recommends default-jre-headless aapt apktool \
    && rm -rf /var/lib/apt/lists/* \
    && (apktool --version 2>&1 | head -1 || true) \
    || echo "WARN: apktool install failed"

# Triton:高级 DSE / taint analysis
RUN python3 -m pip install triton-library \
    && python3 -c "import triton; print('triton OK')" \
    || echo "WARN: triton install failed"

# rr:reverse debugger(需要 SYS_PTRACE + ptrace_scope=0 at runtime)
RUN apt-get update \
    && apt-get install -y --no-install-recommends rr \
    && rm -rf /var/lib/apt/lists/* \
    && (rr --version 2>&1 | head -1 || true) \
    || echo "WARN: rr install failed (runtime needs SYS_PTRACE + ptrace_scope=0)"

# pwndbg:gdb 增强插件(PWN/REV 共用,大幅提升 gdb 交互体验)
RUN set -eux; \
    if [ ! -d /opt/pwndbg ]; then \
      git clone --depth=1 https://github.com/pwndbg/pwndbg /opt/pwndbg || { echo "WARN: pwndbg clone failed"; exit 0; }; \
    fi; \
    if [ -x /opt/pwndbg/setup.sh ]; then \
      cd /opt/pwndbg && ./setup.sh || echo "WARN: pwndbg setup.sh failed (deps may be missing)"; \
      printf '\nsource /opt/pwndbg/gdbinit.py\n' >> /root/.gdbinit; \
    fi

# binwalk-extract plugins 增强(已装 binwalk,补充 SAS 解压支持)
RUN python3 -m pip install sasquatch 2>&1 || echo "WARN: sasquatch pip install failed (optional binwalk plugin)"

# update revlab-check to include v2 tools
RUN printf '#!/usr/bin/env bash\nset +e\necho "[revlab] tool check (v2)"\nfor c in file strings tshark capinfos tcpdump binwalk upx readelf objdump nm gdb strace ltrace python3 scapy r2 rizin go unzip xxd jq patchelf radare2 qemu-aarch64-static qemu-mips-static qemu-riscv64-static one_gadget seccomp-tools uncompyle6 decompyle3 wasm-objdump wasm2wat GoReSym apktool aapt rr; do\n  command -v "$c" >/dev/null 2>&1 && echo "OK $c" || echo "MISS $c"\ndone\ncommand -v go >/dev/null 2>&1 && go version | sed "s/^/GO /"\necho "[revlab] python packages"\npython3 - <<"PY"\nfrom importlib import util\nfor m in ["Crypto", "Cryptodome", "scapy", "pyshark", "dpkt", "lief", "frida", "capstone", "unicorn", "z3", "angr", "claripy", "pwn", "pwnlib", "qiling", "triton", "uncompyle6", "decompyle3"]:\n    name = "Cryptodome" if m == "Cryptodome" else m\n    spec = util.find_spec(name)\n    print(("OK" if spec else "MISS") + " " + m)\nPY\necho "[revlab] ruby gems"\nfor g in one_gadget seccomp-tools; do command -v "$g" >/dev/null 2>&1 && echo "OK $g" || echo "MISS $g"; done\necho "[revlab] go tools"\nfor g in GoReSym; do command -v "$g" >/dev/null 2>&1 && echo "OK $g" || ls /root/go/bin/ 2>/dev/null | grep -i "$g" && echo "OK $g (in /root/go/bin)" || echo "MISS $g"; done\n' > /usr/local/bin/revlab-check \
    && chmod +x /usr/local/bin/revlab-check

# binwalk (pip 提供,但优先 apt,失败 fallback)
RUN apt-get update \
    && apt-get install -y --no-install-recommends binwalk || python3 -m pip install binwalk \
    && rm -rf /var/lib/apt/lists/*

# 可选:配置 pip 镜像
RUN if [ -n "$PIP_INDEX_URL" ]; then \
      mkdir -p /root/.pip; \
      printf '[global]\nindex-url = %s\n' "$PIP_INDEX_URL" > /root/.pip/pip.conf; \
      if [ -n "$PIP_TRUSTED_HOST" ]; then \
        printf 'trusted-host = %s\n' "$PIP_TRUSTED_HOST" >> /root/.pip/pip.conf; \
      fi; \
      echo "==> using pip index: $PIP_INDEX_URL"; \
    fi

# Python solver/tool stack
RUN (python3 -m pip install --upgrade pip setuptools wheel || echo "WARN: pip bootstrap failed") \
    && for pkg in \
      pwntools \
      ROPGadget \
      ropper \
      capstone \
      unicorn \
      keystone-engine \
      pyelftools \
      angr \
      claripy \
      z3-solver \
      requests \
      scapy \
      pycryptodome \
      pycryptodomex \
      pyshark \
      dpkt \
      lief \
      dnfile \
      frida-tools \
      ipython \
      orjson; \
    do \
      python3 -m pip install "$pkg" || echo "WARN: optional pip package failed: $pkg"; \
    done

# 可选:Go 模块代理
RUN if [ -n "$GOPROXY" ]; then \
      go env -w GOPROXY="$GOPROXY"; \
      echo "==> using GOPROXY: $GOPROXY"; \
    fi

# 检查 Go 工具链可用性并写一份 fallback 说明
RUN set -eux; \
    go version || echo "WARN: go toolchain missing"; \
    go tool nm 2>&1 | head -n 1 || true; \
    go tool objdump 2>&1 | head -n 1 || true

# 入口
RUN printf '#!/usr/bin/env bash\nset -euo pipefail\nif [[ $# -eq 0 ]]; then exec bash; fi\nexec "$@"\n' > /usr/local/bin/revlab-entrypoint \
    && chmod +x /usr/local/bin/revlab-entrypoint

WORKDIR /work
CMD ["bash"]
